# Copy this to .env for local dev, and set these in Netlify > Site settings > Environment variables

# JWT secret — make this a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_change_this

# SMTP settings for sending verification emails
# Works with Gmail (use App Password), Mailgun, SendGrid SMTP, Brevo, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noahtxrp@gmail.com
SMTP_PASS=Noah2023

# The URL your site is deployed at (no trailing slash)
# For local dev: http://localhost:8888
# For production: https://yoursite.netlify.app
SITE_URL=http://localhost:8888

# From address shown in verification emails
EMAIL_FROM=Globe Chat <noreply@globechat.com>
